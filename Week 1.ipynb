def caesar(text, shift):
    # TODO: implement this function
    shift = shift % 26 
    new_str=""
    for char in text:
        if(ord(char)< 91-shift and ord(char) > 64):
            val=ord(char)+shift
            new_char=chr(val)
            new_str=new_str+new_char
        elif(ord(char) > 90-shift and ord(char) < 91):
            val=ord(char)+shift-26
            new_char=chr(val)
            new_str=new_str+new_char
        elif(ord(char)< 123-shift and ord(char) > 96):
            val=ord(char)+shift
            new_char=chr(val)
            new_str=new_str+new_char
        elif(ord(char) > 122-shift and ord(char) < 123):
            val=ord(char)+shift-26
            new_char=chr(val)
            new_str=new_str+new_char
        else:
            new_str=new_str+char
    return new_str

def is_balanced(s):
    # TODO: implement this function
    stack = []                             
    pairs = {')': '(', ']': '[', '}': '{'}  
    for char in s:
        if char in '([{':                  
            stack.append(char)
        elif char in ')]}':                
            if not stack:                 
                return False
            if stack.pop() != pairs[char]:  
                return False
    return not stack

def flatten(nested):
    # TODO: implement this function
    if not nested:
        return []
    item=nested.pop()
    if isinstance(item, list):
        return flatten(nested)+flatten(item)
    else:
        return flatten(nested)+[item]
    pass
def encode(s):
    # TODO: implement
    count=1
    newstr=''
    if len(s)==0:
        return newstr
    if len(s) == 1: 
        return "1" + s
    for i in range(1,len(s)):
        if s[i]==s[i-1]:
            count+=1
        else:
            newstr+= str(count)+s[i-1]
            count=1
    newstr+=str(count)+s[-1]
    return newstr
    pass

def decode(s):
    newstr=''
    val=''
    for i in range(0,len(s)):
        if s[i].isalpha():
            newstr+=int(val)*s[i]
            val=''
        else:
            val+=s[i]
    return newstr

class Student:
    def __init__(self, name):
        # TODO
        self.name=name
        self.grades={}
        pass

    def add_grade(self, subject, mark):
        # TODO
        self.grades[subject]=mark
        pass

    def average(self):
        # TODO
        if len(self.grades)!=0:
            return sum(self.grades.values()) / len(self.grades)
        else:
            return 0
        pass

    def top_subject(self):
        # TODO
        if not self.grades:
            return 0
        max_subject=max(self.grades, key=self.grades.get)
        return max_subject
        pass

    def report(self):
        # TODO
        print(f'Report Card: {self.name}')
        for key in self.grades.keys():
            gap=(9-len(key))*' '
            print(' ',key,gap,':',self.grades[key])
        print('Average: ',self.average(),' | Top Subject:',self.top_subject())

