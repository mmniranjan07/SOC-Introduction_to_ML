   "source": [
    "alphas = [0.001, 0.005, 0.01, 0.05, 0.1, 0.5]\n",
    " \n",
    "for label, test_size in splits.items():\n",
    "    X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=test_size)\n",
    "    print(f\"\\n  Split {label}\")\n",
    "    print(f\"  {'Alpha':<8}  {'Ridge MSE':>13}  {'Ridge R²':>10}  {'Lasso MSE':>12}  {'Lasso R²':>10}\")\n",
    " \n",
    "    for alpha in alphas:\n",
    "        ridge = Ridge(alpha=alpha)\n",
    "        ridge.fit(X_train, y_train)\n",
    "        r_mse = mean_squared_error(y_test, ridge.predict(X_test))\n",
    "        r_r2  = r2_score(y_test, ridge.predict(X_test))\n",
    "        lasso = Lasso(alpha=alpha, max_iter=10000)\n",
    "        lasso.fit(X_train, y_train)\n",
    "        l_mse = mean_squared_error(y_test, lasso.predict(X_test))\n",
    "        l_r2  = r2_score(y_test, lasso.predict(X_test))\n",
    "        print(f\"  {alpha:<8}  {r_mse:>12.4f}  {r_r2:>10.4f}  {l_mse:>12.4f}  {l_r2:>10.4f}\")"
