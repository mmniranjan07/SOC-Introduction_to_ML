   "source": [
    "lr=LinearRegression()\n",
    "X = df\n",
    "y = raw_target\n",
    "X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.2)\n",
    "lr.fit(X_train, y_train)\n",
    "y_pred = lr.predict(X_test)\n",
    "for name, coef in zip(X.columns, lr.coef_):\n",
    "    print(f\"  {name:<12}: {coef:>12.5f}\")\n",
    "print(f\"  {'Intercept':<12}: {lr.intercept_:>12.5f}\\n\")\n",
    "print(f\"  MAE         : {mean_absolute_error(y_test, y_pred):>12.5f}\")\n",
    "print(f\"  MSE         : {mean_squared_error(y_test, y_pred):>12.5f}\")\n",
    "print(f\"  R2 Score    : {r2_score(y_test, y_pred):>12.5f}\")\n",
    "print(f\"  Coefficient : {lr.coef_[0]:>12.5f}\")\n",
    "print(f\"  Intercept   : {lr.intercept_:>12.5f}\")"
   ]
